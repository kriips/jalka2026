# Environment variable placeholders for Leaderboard Feed feature
# Toggle feed ingestion on/off
FEED_ENABLED=false
# External feed base URL (e.g. https://api.example.com/results)
FEED_URL=
# API key (header X-Feed-Api-Key)
FEED_API_KEY=
# Polling interval in seconds (default 120)
POLLING_INTERVAL_SECONDS=120
# Maximum retries for a single fetch cycle
MAX_RETRIES=5
# Backoff base milliseconds
BACKOFF_BASE_MS=500
# Jitter milliseconds max
BACKOFF_JITTER_MS=250
